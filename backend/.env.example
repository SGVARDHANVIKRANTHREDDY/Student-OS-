# ─── Student OS — Environment Variables ───
# Copy this file to `.env` and fill in values for your environment.

# ── Core ──
NODE_ENV=development
PORT=5000
HOST=127.0.0.1

# ── Authentication ──
# Required in production. In dev, a random ephemeral secret is generated if unset.
JWT_SECRET=replace-with-strong-secret
#JWT_EXPIRY=1h
#REFRESH_TOKEN_EXPIRY_DAYS=30

# ── Google SSO (optional) ──
#GOOGLE_CLIENT_ID=your-google-oauth-client-id
#GOOGLE_CLIENT_SECRET=

# ── PostgreSQL (optional — used for jobs, postings, applications) ──
# Set PG_URL or PGHOST to enable.
#PG_URL=postgres://user:password@localhost:5432/student_system
#PG_READ_URL=
#PGHOST=
#PGUSER=student
#PGPASSWORD=student
#PGDATABASE=student_system
#PGPORT=5432
# SSL: auto-enabled in production. Set PG_SSL=0 to disable (e.g. in-VPC).
#PG_SSL=1
#PGPOOL_MAX=20
#PG_STATEMENT_TIMEOUT_MS=10000

# ── Redis (optional — BullMQ, rate limiting) ──
#REDIS_URL=redis://localhost:6379
#REDIS_HOST=127.0.0.1
#REDIS_PORT=6379

# ── CORS ──
# Comma-separated origins. If unset, CORS is disabled (same-origin mode).
#CORS_ORIGIN=http://localhost:3000

# ── HTTP Tuning ──
#JSON_BODY_LIMIT=1mb
#TRUST_PROXY=1
#HTTP_REQUEST_TIMEOUT_MS=30000

# ── Logging ──
#LOG_LEVEL=info
